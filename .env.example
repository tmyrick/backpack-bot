# RIDB API key - register at https://ridb.recreation.gov/ to get one
RIDB_API_KEY=

# Server port (default: 3001)
PORT=3001

# Recreation.gov credentials (only needed for booking automation)
RECGOV_EMAIL=
RECGOV_PASSWORD=

# Address for order details (auto-filled during booking)
RECGOV_ADDRESS=
RECGOV_CITY=
RECGOV_STATE=
RECGOV_ZIP=
RECGOV_COUNTRY=USA

# Recreation.gov credentials (only needed for booking automation)
# RECGOV_EMAIL=your-email@example.com
# RECGOV_PASSWORD=your-password
