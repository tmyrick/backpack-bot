# RIDB API key - register at https://ridb.recreation.gov/ to get one
RIDB_API_KEY=

# Server port (default: 3001)
PORT=3001

# Recreation.gov credentials (only needed for booking automation)
RECGOV_EMAIL=
RECGOV_PASSWORD=

# Address for order details (auto-filled during booking)
RECGOV_ADDRESS=
RECGOV_CITY=
RECGOV_STATE=
RECGOV_ZIP=
RECGOV_COUNTRY=USA

# Optional: run browser in headed mode (visible window) for local debugging.
# Set to "false" to see the browser; may help with reCAPTCHA and session persistence.
# HEADLESS=false

# Optional: magenta pulse around elements before each sniper click (default: off).
# Local testing only; only applies when HEADLESS=false. Set to true or 1 to enable.
# Also skips the permit grid "unavailable dates" early exit, allows disabled date buttons, matches
# cells by trail + date only (ignores "- Unavailable" / "- Available"), clicks only first & last night
# of the range (not every night), and avoids cross-row fallbacks when a trailhead is set.
# VISUAL_CLICKS=true

# Optional: residential proxy for cloud deployments (fly.io, etc.)
# Recreation.gov blocks datacenter IPs. Use a residential proxy to avoid this.
# Format: http://username:password@host:port
# PROXY_SERVER=
